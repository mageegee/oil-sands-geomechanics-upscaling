
;================================================test_z==========================================================
fish define perm_z_1
    local replace = file.delete('z_perm_realization'+string(realization_number)+'_step1.dat')
    local output = file.open('z_perm_realization'+string(realization_number)+'_step1.dat','append','text'); append new lines for each model running
    local w = list
    local zp = zone.head
    loop while zp # null
        local permeability = zone.fluid.prop(zp, 'permeability')
        permeability = permeability/md
        local a_ii=string.build("%1",string(permeability))
        zp = zone.next(zp)
        w=list.append(w,a_ii)
    endloop
    file.write(output,w)
    file.close(output)
end
