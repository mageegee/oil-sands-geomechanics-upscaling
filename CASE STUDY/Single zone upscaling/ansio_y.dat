model new
model large-strain off
model config fluid
model fluid active on
model configure plugins
[global size = 1]
[global k = 2.8e-7]
zone create brick size [size], [size], [size] ...;5 zones in each axis
                  point 0   0,   0,   0,...
                  point 1   1,   0,   0 ... ;1m x 1m x 1m dimension
                  point 2   0,   1,   0 ...
                  point 3   0,   0,   1
zone face skin

;=======materila properties========
zone cmodel assign anisotropic-strain-softening
zone property Ex 1.89e5 Ey 1.81e5 Ez 1.9e5 nuxy 0.4 nuyz 0.4 nuzx 0.4 friction-x 26 friction-y 25 friction-z 26  cohesion-x 487 cohesion-y 472 cohesion-z 490
zone property Kx 2.9e5 Ky 2.86e5 Kz 2.96e5 Gx 6.89e4 Gy 6.5e4 Gz 6.5e4 dilation-x 12.13 dilation-y 10.73 dilation-z 11.89
zone property table-friction-x 'fricx' table-friction-y 'fricy' table-friction-z 'fricz' table-dilation-x 'dilx' table-dilation-y 'dily' table-dilation-z 'dilz' ...
table-cohesion-x 'cohx' table-cohesion-y 'cohy' table-cohesion-z 'cohz'

