;=======fluid boundary condition=======
zone fluid cmodel assign anisotropic
zone fluid property permeability-xx  [k]
zone fluid property permeability-yy 2.61E-7
zone fluid property permeability-zz 2.49E-7

zone fluid biot off ;[off] compressible water [on] imcompressible water / compressible grain
zone initialize fluid-density 1
zone gridpoint initialize fluid-tension -1e15 ; fluid tension limit, water is unbreakable
zone gridpoint initialize fluid-modulus 2e4 ;compressibility of water (opposite force)
;;=========saturation====================
zone gridpoint initialize saturation 1.0;fully saturated cube
zone gridpoint initialize pore-pressure 981
;zone gridpoint fix pore-pressure 981
zone face apply pore-pressure 981
;=======boundary condition=======
zone gridpoint initialize velocity (0,0,0)
zone gridpoint initialize displacement (0,0,0)
zone initialize stress xx -2000. yy -2000. zz -2000.
zone face apply stress-norm -2000. range group 'Top' or 'Bottom'
zone face apply stress-norm -2000. range group 'West' or 'East'
zone face apply velocity-y 0 range group 'South'


program call 'fish aniso'
zone face apply velocity-y -1e-5 range group 'North'
history interval 300


model fluid active on
model mechanical slave on
model fluid substep 1
model mechanical substep 1
model fluid timestep fix 1e-5
zone gridpoint initialize fluid-modulus 5e4
model cycle 3000
[update_perm_y]
zone gridpoint initialize fluid-modulus 2e4
model fluid timestep fix 3e-3
history interval 500
model cycle 1000
[update_perm_y]
model cycle 1500
[update_perm_y]
model cycle 2000
[update_perm_y]
model cycle 4000
[update_perm_y]
model cycle 2000


model save '109_y_aniso'



history export '8' vs '6' table '109_y_qa_aniso
history export '10' vs '6' table '109_y_vol_aniso'
history export '12' vs '6' table '109_y_pp_aniso'
table '109_y_qa_aniso' export '109_y_qa_aniso' truncate
table '109_y_vol_aniso' export '109_y_vol_aniso' truncate
table '109_y_pp_aniso' export '109_y_pp_aniso' truncate



