
;================================================test_z==========================================================
fish define ps_z_1
    local replace = file.delete('z_shearstrain_realization'+string(realization_number)+'_step1.dat')
    local output = file.open('z_shearstrain_realization'+string(realization_number)+'_step1.dat','append','text'); append new lines for each model running
    local w = list
    local zp = zone.head
    loop while zp # null
        local single_plastic_strain = zone.prop(zp,'strain-shear-plastic')
        local a_ii=string.build("%1",string(single_plastic_strain))
        zp = zone.next(zp)
        w=list.append(w,a_ii)
    endloop
    file.write(output,w)
    file.close(output)
end
