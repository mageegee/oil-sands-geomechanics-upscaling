fish define test_z
    command
        program call 'operate'
        program call 'history'
        program call 'flow_zdirection'
        program call 'bc'
        program call 'ps'
        program call 'vol'
        program call 'perm'
        [bc_setup_z]
        [step_ini_perm]
        [ps_z_1];plastic history
        [vol_z_1];volumetric history
        [perm_z_1];permeability history
        [bc_removepp_z]
        [fh_z_z_1]     
        [bc_resetup_z]
        [bc_removepp_y]
        [fh_z_y_1]
        [bc_resetup_z]
        [bc_removepp_x]
        [fh_z_x_1]
        [flow_out_z_step1]
;5
        ;--------second part--------
        [bc_resetup_z]
        [step];3000
        [ps_z_2]
        [vol_z_2]
        [perm_z_2]
        [bc_removepp_z]
        [fh_z_z_2]
        [bc_resetup_z]
        [bc_removepp_y]
        [fh_z_y_2]
        [bc_resetup_z]
        [bc_removepp_x]
        [fh_z_x_2]
        [flow_out_z_step2]
;3000        
        ;--------third part--------
        [bc_resetup_z]
        [step];40100
        [ps_z_3]
        [vol_z_3]
        [perm_z_3]
        [bc_removepp_z]
        [fh_z_z_3]
        [bc_resetup_z]
        [bc_removepp_y]
        [fh_z_y_3]
        [bc_resetup_z]
        [bc_removepp_x]
        [fh_z_x_3]
        [flow_out_z_step3]
;6000        
        ;--------forth part--------
        [bc_resetup_z]
        [step];60200
        [ps_z_4]
        [vol_z_4]
        [perm_z_4]
        [bc_removepp_z]
        [fh_z_z_4]
        [bc_resetup_z]
        [bc_removepp_y]
        [fh_z_y_4]
        [bc_resetup_z]
        [bc_removepp_x]
        [fh_z_x_4]
        [flow_out_z_step4]
;9000   
        ;--------fivth part--------
        [bc_resetup_z]
        [step];80300
        [ps_z_5]
        [vol_z_5]
        [perm_z_5]
        [bc_removepp_z]
        [fh_z_z_5]
        [bc_resetup_z]
        [bc_removepp_y]
        [fh_z_y_5]
        [bc_resetup_z]
        [bc_removepp_x]
        [fh_z_x_5]
        [flow_out_z_step5]
;12000      
        ;--------final--------
        [bc_resetup_z]
        [step_final];19000
        [ps_z_6]
        [vol_z_6]
        [perm_z_6]
        [bc_removepp_z]
        [fh_z_z_6]
        [bc_resetup_z]
        [bc_removepp_y]
        [fh_z_y_6]
        [bc_resetup_z]
        [bc_removepp_x]
        [fh_z_x_6]
        [flow_out_z_step6]
        [bc_resetup_z]
        [step_final]
        model save ['ss_z_realization_'+string(realization_number)]
        [history_z]
    endcommand
end
